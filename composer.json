{
  "type": "prestashop-module",
  "name": "prestashop/pskyc",
  "description": "Open source, GDPR-compliant KYC document verification for PrestaShop.",
  "license": "MIT",
  "homepage": "https://github.com/vachmara/pskyc",
  "authors": [
      {
          "name": "Valentin Chmara",
          "email": "valentin@supadev.fr"
      }
  ],
  "require": {
    "php": ">=7.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5",
    "mockery/mockery": "^1.4",
    "symfony/phpunit-bridge": "^5.4",
    "phpstan/phpstan": "^1.0",
    "squizlabs/php_codesniffer": "^3.6"
  },
  "config": {
    "platform": {
      "php": "7.3"
    },
    "preferred-install": "dist",
    "classmap-authoritative": true,
    "optimize-autoloader": true,
    "sort-packages": true,
    "prepend-autoloader": false
  },
  "autoload": {
    "psr-4": {
      "PrestaShop\\Module\\Pskyc\\": "src/",
      "PrestaShop\\Module\\Pskyc\\Tests\\": "tests/PsKyc"
    },
    "classmap": [
      "pskyc.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
  }
}
