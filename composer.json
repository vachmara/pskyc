{
    "type": "prestashop-module",
    "name": "prestashop/pskyc",
    "description": "Open source, GDPR-compliant KYC document verification for PrestaShop 8.",
    "license": "OSL-3.0",
    "homepage": "https://github.com/vachmara/pskyc",
    "authors": [
        {
            "name": "PrestaShop SA",
            "email": "contact@prestashop.com"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "mockery/mockery": "^1.4",
        "prestashop/php-dev-tools": "^4.2",
        "mikey179/vfsstream": "^1.6"
    },
    "config": {
        "platform": {
            "php": "8.1"
        },
        "preferred-install": "dist",
        "classmap-authoritative": true,
        "optimize-autoloader": true,
        "sort-packages": true,
        "prepend-autoloader": false
    },
    "autoload": {
        "psr-4": {
            "PrestaShop\\Module\\Pskyc\\": "src/"
        },
        "classmap": [
            "pskyc.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\PsKyc\\": "tests/PsKyc/"
        }
    },
    "scripts": {
        "set-license-header": [
            "@php ./vendor/bin/header-stamp --license=\"mit.txt\" --exclude=\".github,node_modules,vendor\""
        ],
        "lint": [
            "php-cs-fixer fix --no-interaction"
        ],
        "lint-check": [
            "php-cs-fixer fix --no-interaction --dry-run --diff"
        ]
    }
}
