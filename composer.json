{
  "type": "prestashop-module",
  "name": "prestashop/pskyc",
  "description": "Open source, GDPR-compliant KYC document verification for PrestaShop.",
  "license": "MIT",
  "homepage": "https://github.com/vachmara/pskyc",
  "authors": [
      {
          "name": "Valentin Chmara",
          "email": "valentin@supadev.fr"
      }
  ],
  "config": {
    "platform": {
      "php": "7.3"
    },
    "preferred-install": "dist",
    "classmap-authoritative": true,
    "optimize-autoloader": true,
    "sort-packages": true,
    "prepend-autoloader": false
  },
  "autoload": {
    "psr-4": {
      "Prestashop\\Module\\Pskyc\\": "src/"
    },
    "classmap": [
      "pskyc.php"
    ]
  }
}