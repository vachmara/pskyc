parameters:
  paths:
    # Paths are now absolute within the container
    - /var/www/html/modules/pskyc/pskyc.php
    - /var/www/html/modules/pskyc/controllers/
    - /var/www/html/modules/pskyc/src/
  
  reportUnmatchedIgnoredErrors: false
  level: 5
  
  # Memory limit for analysis
  memoryLimit: 1G
  
  # PrestaShop 8 specific ignores
  ignoreErrors:
    - '#Call to an undefined method.*::trans\(\)#'
    - '#Access to an undefined property.*::\$context#'
    - '#Call to an undefined method.*::get\(\)#'
    - '#Parameter \#1 \$hookParams of method.*::hookActionListMailThemes\(\) expects array, mixed given#'
    
  # Bootstrap for better context - use absolute path in container
  bootstrapFiles:
    - /var/www/html/modules/pskyc/tests/bootstrap.php
  
  # PrestaShop environment variable
  scanDirectories:
    - /var/www/html