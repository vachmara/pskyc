# Compatible .htaccess for older Apache versions

# Allow all image files (Apache 2.2/2.4 compatible)
<Files "logo.png">
    Order allow,deny
    Allow from all
    Satisfy any
</Files>

<FilesMatch "\.(png|jpg|jpeg|gif|svg|ico|css|js)$">
    Order allow,deny
    Allow from all
    Satisfy any
</FilesMatch>

# Block sensitive files
<Files "composer.json">
    Order deny,allow
    Deny from all
</Files>

<Files "composer.lock">
    Order deny,allow
    Deny from all
</Files>

# Prevent directory browsing
Options -Indexes