<tr>
	<td align="center" class="titleblock">
		<font size="2" face="{{ languageDefaultFont }}Open-sans, sans-serif" color="#555454">
			<span class="title">{{ 'KYC Verification Status Update'|trans({}, 'Modules.Pskyc.Shop', locale)|raw }}</span>
		</font>
	</td>
</tr>
<tr>
	<td class="space_footer">&nbsp;</td>
</tr>

<tr>
	<td class="box" align="center" width="100%">
		<table class="table" cellpadding="0" cellspacing="0">
			<tr>
				<td width="10">&nbsp;</td>
				<td>
					<font size="2" face="{{ languageDefaultFont }}Open-sans, sans-serif" color="#555454">
						<p>{{ 'Dear'|trans({}, 'Modules.Pskyc.Shop', locale) }}
							{firstname} {lastname},</p>

						<p>{{ 'Your KYC verification status has been updated.'|trans({}, 'Modules.Pskyc.Shop', locale) }}</p>

						<table class="table" cellpadding="5" cellspacing="0" style="width:100%; border: 1px solid #d6d4d4;">
							<tr style="background-color: #fbfbfb;">
								<td style="border-right: 1px solid #d6d4d4;">
									<strong>{{ 'Verification ID'|trans({}, 'Modules.Pskyc.Shop', locale) }}:</strong>
								</td>
								<td>#{verification_id}</td>
							</tr>
							<tr>
								<td style="border-right: 1px solid #d6d4d4;">
									<strong>{{ 'Status'|trans({}, 'Modules.Pskyc.Shop', locale) }}:</strong>
								</td>
								<td>
									<span style="padding: 4px 8px; background-color: {status_color}; color: white; border-radius: 3px; font-size: 11px; text-transform: uppercase;">
										{status_label}
									</span>
								</td>
							</tr>
							<tr style="background-color: #fbfbfb;">
								<td style="border-right: 1px solid #d6d4d4;">
									<strong>{{ 'Date Submitted'|trans({}, 'Modules.Pskyc.Shop', locale) }}:</strong>
								</td>
								<td>{date_submitted}</td>
							</tr>
							{if isset($date_validated)}
							<tr>
								<td style="border-right: 1px solid #d6d4d4;">
									<strong>{{ 'Date Processed'|trans({}, 'Modules.Pskyc.Shop', locale) }}:</strong>
								</td>
								<td>{date_validated}</td>
							</tr>
							{/if}
														                                {if isset($date_expiry)}
							<tr style="background-color: #fbfbfb;">
								<td style="border-right: 1px solid #d6d4d4;">
									<strong>{{ 'Valid Until'|trans({}, 'Modules.Pskyc.Shop', locale) }}:</strong>
								</td>
								<td>{date_expiry}</td>
							</tr>
							{/if}
						</table>

                                                {# Admin notes are not sent to customers anymore #}

						<table cellpadding="0" cellspacing="0" style="margin: 20px auto;">
							<tr>
								<td align="center">
									<a href="{shop_url}" style="color:#337ff1; font-weight:bold; text-decoration:none; background-color: #337ff1; border: 1px solid #337ff1; color: #fff; padding: 10px 15px; display: inline-block; border-radius: 3px;">
										{action_button_text}
									</a>
								</td>
							</tr>
						</table>

						<p style="font-style: italic; font-size: 11px; color: #666;">
							{{ 'This is an automated message. Please do not reply to this email.'|trans({}, 'Modules.Pskyc.Shop', locale) }}
						</p>
					</font>
				</td>
				<td width="10">&nbsp;</td>
			</tr>
		</table>
	</td>
</tr></tr
