<table width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;">
	<tr>
		<td align="center" class="titleblock">
			<font size="2" face="{{ languageDefaultFont }}Open-sans, sans-serif" color="#555454">
				<span class="title">{{ 'KYC Verification Expiry Warning'|trans({}, 'Modules.Pskyc.Shop', locale)|raw }}</span>
			</font>
		</td>
	</tr>
	<tr>
		<td class="space_footer">&nbsp;</td>
	</tr>

	<tr>
		<td class="box" align="center" width="100%">
			<table class="table" cellpadding="0" cellspacing="0">
				<tr>
					<td width="10">&nbsp;</td>
					<td>
						<font size="2" face="{{ languageDefaultFont }}Open-sans, sans-serif" color="#555454">
							<p>{{ 'Dear'|trans({}, 'Modules.Pskyc.Shop', locale) }}
								{firstname} {lastname},</p>

							<p>{{ 'Your KYC verification is approaching its expiry date.'|trans({}, 'Modules.Pskyc.Shop', locale) }}</p>

							<table class="table" cellpadding="5" cellspacing="0" style="width:100%; border: 1px solid #d6d4d4;">
								<tr style="background-color: #fbfbfb;">
									<td style="border-right: 1px solid #d6d4d4;">
										<strong>{{ 'Verification ID'|trans({}, 'Modules.Pskyc.Shop', locale) }}:</strong>
									</td>
									<td>#{verification_id}</td>
								</tr>
								<tr>
									<td style="border-right: 1px solid #d6d4d4;">
										<strong>{{ 'Current Status'|trans({}, 'Modules.Pskyc.Shop', locale) }}:</strong>
									</td>
									<td>
										<span style="padding: 4px 8px; background-color: #28a745; color: white; border-radius: 3px; font-size: 11px; text-transform: uppercase;">
											{{ 'Approved'|trans({}, 'Modules.Pskyc.Shop', locale) }}
										</span>
									</td>
								</tr>
								<tr style="background-color: #fbfbfb;">
									<td style="border-right: 1px solid #d6d4d4;">
										<strong>{{ 'Expires On'|trans({}, 'Modules.Pskyc.Shop', locale) }}:</strong>
									</td>
									<td>
										<strong style="color: #dc3545;">{expiry_date}</strong>
									</td>
								</tr>
								<tr>
									<td style="border-right: 1px solid #d6d4d4;">
										<strong>{{ 'Days Remaining'|trans({}, 'Modules.Pskyc.Shop', locale) }}:</strong>
									</td>
									<td>
										<strong style="color: #dc3545;">{days_remaining}</strong>
									</td>
								</tr>
							</table>

							<table class="table" cellpadding="10" cellspacing="0" style="width:100%; border: 1px solid #ffc107; background-color: #fff3cd; margin: 15px 0;">
								<tr>
									<td style="color: #856404;">
										<strong>{{ 'Action Required'|trans({}, 'Modules.Pskyc.Shop', locale) }}</strong><br>
										{{ 'To maintain uninterrupted access to our services, please renew your KYC verification before the expiry date.'|trans({}, 'Modules.Pskyc.Shop', locale) }}
									</td>
								</tr>
							</table>

							<table cellpadding="0" cellspacing="0" style="margin: 20px auto;">
								<tr>
									<td align="center">
										<a href="{renewal_url}" style="color:#fff; font-weight:bold; text-decoration:none; background-color: #ffc107; border: 1px solid #ffc107; color: #000; padding: 10px 15px; display: inline-block; border-radius: 3px;">
											{{ 'Renew Verification'|trans({}, 'Modules.Pskyc.Shop', locale) }}
										</a>
									</td>
								</tr>
							</table>

							<p style="font-size: 11px; color: #666;">
								{{ 'If you have any questions, please contact our support team.'|trans({}, 'Modules.Pskyc.Shop', locale) }}
							</p>

							<p style="font-style: italic; font-size: 11px; color: #666;">
								{{ 'This is an automated message. Please do not reply to this email.'|trans({}, 'Modules.Pskyc.Shop', locale) }}
							</p>
						</font>
					</td>
					<td width="10">&nbsp;</td>
				</tr>
			</table>
		</td>
	</tr>
</table>
