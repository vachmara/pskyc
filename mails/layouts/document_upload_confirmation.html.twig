<tr>
	<td align="center" class="titleblock">
		<font size="2" face="{{ languageDefaultFont }}Open-sans, sans-serif" color="#555454">
			<span class="title">{{ 'KYC Document Upload Confirmation'|trans({}, 'Modules.Pskyc.Shop', locale)|raw }}</span>
		</font>
	</td>
</tr>
<tr>
	<td class="space_footer">&nbsp;</td>
</tr>

<tr>
	<td class="box" align="center" width="100%">
		<table class="table" cellpadding="0" cellspacing="0">
			<tr>
				<td width="10">&nbsp;</td>
				<td>
					<font size="2" face="{{ languageDefaultFont }}Open-sans, sans-serif" color="#555454">
						<p>{{ 'Dear'|trans({}, 'Modules.Pskyc.Shop', locale) }}
							{firstname} {lastname},</p>

						<p>{{ 'Thank you for uploading your KYC verification documents.'|trans({}, 'Modules.Pskyc.Shop', locale) }}</p>

						<table class="table" cellpadding="5" cellspacing="0" style="width:100%; border: 1px solid #d6d4d4;">
							<tr style="background-color: #fbfbfb;">
								<td style="border-right: 1px solid #d6d4d4;">
									<strong>{{ 'Verification ID'|trans({}, 'Modules.Pskyc.Shop', locale) }}:</strong>
								</td>
								<td>#{verification_id}</td>
							</tr>
							<tr>
								<td style="border-right: 1px solid #d6d4d4;">
									<strong>{{ 'Upload Date'|trans({}, 'Modules.Pskyc.Shop', locale) }}:</strong>
								</td>
								<td>{upload_date}</td>
							</tr>
							<tr style="background-color: #fbfbfb;">
								<td style="border-right: 1px solid #d6d4d4;">
									<strong>{{ 'Number of Documents'|trans({}, 'Modules.Pskyc.Shop', locale) }}:</strong>
								</td>
								<td>{document_count}</td>
							</tr>
						</table>

						<table class="table" cellpadding="10" cellspacing="0" style="width:100%; border: 1px solid #28a745; background-color: #d4edda; margin: 15px 0;">
							<tr>
								<td style="color: #155724;">
									<strong>{{ 'What happens next?'|trans({}, 'Modules.Pskyc.Shop', locale) }}</strong><br>
									{{ 'Our verification team will review your documents within 24-48 hours. You will receive an email notification once the review is complete.'|trans({}, 'Modules.Pskyc.Shop', locale) }}
								</td>
							</tr>
						</table>

						<table cellpadding="0" cellspacing="0" style="margin: 20px auto;">
							<tr>
								<td align="center">
									<a href="{verification_status_url}" style="color:#337ff1; font-weight:bold; text-decoration:none; background-color: #337ff1; border: 1px solid #337ff1; color: #fff; padding: 10px 15px; display: inline-block; border-radius: 3px;">
										{{ 'Check Status'|trans({}, 'Modules.Pskyc.Shop', locale) }}
									</a>
								</td>
							</tr>
						</table>

						<p style="font-style: italic; font-size: 11px; color: #666;">
							{{ 'This is an automated message. Please do not reply to this email.'|trans({}, 'Modules.Pskyc.Shop', locale) }}
						</p>
					</font>
				</td>
				<td width="10">&nbsp;</td>
			</tr>
		</table>
	</td>
</tr>
