<tr>
	<td align="center" class="titleblock">
		<font size="2" face="{{ languageDefaultFont }}Open-sans, sans-serif" color="#555454">
			<span class="title">{{ 'New KYC Verification Request'|trans({}, 'Modules.Pskyc.Admin', locale)|raw }}</span>
		</font>
	</td>
</tr>
<tr>
	<td class="space_footer">&nbsp;</td>
</tr>

<tr>
	<td class="box" align="center" width="100%">
		<table class="table" cellpadding="0" cellspacing="0">
			<tr>
				<td width="10">&nbsp;</td>
				<td>
					<font size="2" face="{{ languageDefaultFont }}Open-sans, sans-serif" color="#555454">
						<p>{{ 'A new KYC verification request has been submitted and requires admin review.'|trans({}, 'Modules.Pskyc.Admin', locale) }}</p>

						<table class="table" cellpadding="5" cellspacing="0" style="width:100%; border: 1px solid #d6d4d4;">
							<tr style="background-color: #fbfbfb;">
								<td style="border-right: 1px solid #d6d4d4;">
									<strong>{{ 'Customer'|trans({}, 'Admin.Global', locale) }}:</strong>
								</td>
								<td>{customer_name} ({customer_email})</td>
							</tr>
							<tr>
								<td style="border-right: 1px solid #d6d4d4;">
									<strong>{{ 'Customer ID'|trans({}, 'Admin.Global', locale) }}:</strong>
								</td>
								<td>#{customer_id}</td>
							</tr>
							<tr style="background-color: #fbfbfb;">
								<td style="border-right: 1px solid #d6d4d4;">
									<strong>{{ 'Verification ID'|trans({}, 'Modules.Pskyc.Admin', locale) }}:</strong>
								</td>
								<td>#{verification_id}</td>
							</tr>
							<tr>
								<td style="border-right: 1px solid #d6d4d4;">
									<strong>{{ 'Date Submitted'|trans({}, 'Admin.Global', locale) }}:</strong>
								</td>
								<td>{date_submitted}</td>
							</tr>
							<tr style="background-color: #fbfbfb;">
								<td style="border-right: 1px solid #d6d4d4;">
									<strong>{{ 'Documents Count'|trans({}, 'Modules.Pskyc.Admin', locale) }}:</strong>
								</td>
								<td>{documents_count}</td>
							</tr>
						</table>

						<table class="table" cellpadding="10" cellspacing="0" style="width:100%; border: 1px solid #ffc107; background-color: #fff3cd; margin: 15px 0;">
							<tr>
								<td style="color: #856404;">
									<strong>{{ 'Action Required'|trans({}, 'Modules.Pskyc.Admin', locale) }}</strong><br>
									{{ 'Please review the submitted documents and update the verification status in the admin panel.'|trans({}, 'Modules.Pskyc.Admin', locale) }}
								</td>
							</tr>
						</table>

						<table cellpadding="0" cellspacing="0" style="margin: 20px auto;">
							<tr>
								<td align="center">
									<a href="{admin_verification_url}" style="color:#fff; font-weight:bold; text-decoration:none; background-color: #ffc107; border: 1px solid #ffc107; color: #000; padding: 10px 15px; display: inline-block; border-radius: 3px;">
										{{ 'Review in Admin Panel'|trans({}, 'Modules.Pskyc.Admin', locale) }}
									</a>
								</td>
							</tr>
						</table>

						<p style="font-style: italic; font-size: 11px; color: #666;">
							{{ 'This is an automated admin notification.'|trans({}, 'Modules.Pskyc.Admin', locale) }}
						</p>
					</font>
				</td>
				<td width="10">&nbsp;</td>
			</tr>
		</table>
	</td>
</tr>
