{% extends '@Modules/pskyc/mails/themes/pskyc/layouts/kyc_base.html.twig' %}

{% block title %}{{ 'New KYC Verification Request'|trans({}, 'Modules.Pskyc.Admin', language.locale) }}{% endblock %}
{% block header_color %}#ffc107{% endblock %}
{% block accent_color %}#ffc107{% endblock %}
{% block header_subtitle %}{{ 'New Verification Request'|trans({}, 'Modules.Pskyc.Admin', language.locale) }}{% endblock %}

{% block content %}
    <p>{{ 'A new KYC verification request has been submitted and requires review.'|trans({}, 'Modules.Pskyc.Admin', language.locale) }}</p>
    
    <div class="info-box">
        <p><strong>{{ 'Customer'|trans({}, 'Admin.Global', language.locale) }}:</strong> {{ customer_name }} ({{ customer_email }})</p>
        <p><strong>{{ 'Customer ID'|trans({}, 'Admin.Global', language.locale) }}:</strong> #{{ customer_id }}</p>
        <p><strong>{{ 'Verification ID'|trans({}, 'Modules.Pskyc.Admin', language.locale) }}:</strong> #{{ verification_id }}</p>
        <p><strong>{{ 'Date Submitted'|trans({}, 'Admin.Global', language.locale) }}:</strong> {{ date_submitted|date('Y-m-d H:i:s') }}</p>
    </div>
    
    <p>{{ 'Please review the submitted documents and update the verification status.'|trans({}, 'Modules.Pskyc.Admin', language.locale) }}</p>
    
    <div style="text-align: center;">
        <a href="{{ admin_url }}" class="button">{{ 'Review in Admin Panel'|trans({}, 'Modules.Pskyc.Admin', language.locale) }}</a>
    </div>
{% endblock %}