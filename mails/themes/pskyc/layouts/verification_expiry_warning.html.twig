{% extends '@Modules/pskyc/mails/themes/pskyc/layouts/kyc_base.html.twig' %}

{% block title %}{{ 'KYC Verification Expiring Soon'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}{% endblock %}
{% block header_color %}#fd7e14{% endblock %}
{% block accent_color %}#fd7e14{% endblock %}
{% block header_subtitle %}{{ 'Expiring Soon'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}{% endblock %}

{% block content %}
    <p>{{ 'Dear'|trans({}, 'Modules.Pskyc.Shop', language.locale) }} {{ customer_name }},</p>
    
    <p>{{ 'Your KYC verification will expire in %days% days.'|trans({'%days%': days_until_expiry}, 'Modules.Pskyc.Shop', language.locale) }}</p>
    
    <div class="info-box">
        <p><strong>{{ 'Verification ID'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}:</strong> #{{ verification_id }}</p>
        <p><strong>{{ 'Expiry Date'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}:</strong> {{ expiry_date|date('Y-m-d H:i:s') }}</p>
        <p><strong>{{ 'Days Remaining'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}:</strong> {{ days_until_expiry }}</p>
    </div>
    
    <div class="alert alert-warning">
        <p><strong>⚠️ {{ 'Action Required'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}:</strong> {{ 'To avoid service interruption, please renew your verification before it expires.'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}</p>
    </div>
    
    <p>{{ 'Renewing your verification is quick and easy. Simply upload your updated documents.'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}</p>
    
    <div style="text-align: center;">
        <a href="{{ renewal_url }}" class="button" style="background-color: #fd7e14;">{{ 'Renew Now'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}</a>
    </div>
{% endblock %}