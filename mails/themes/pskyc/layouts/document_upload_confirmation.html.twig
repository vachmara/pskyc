{% extends '@Modules/pskyc/mails/themes/pskyc/layouts/kyc_base.html.twig' %}

{% block title %}{{ 'KYC Documents Received'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}{% endblock %}
{% block header_color %}#007cba{% endblock %}
{% block accent_color %}#007cba{% endblock %}
{% block header_subtitle %}{{ 'Documents Received'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}{% endblock %}

{% block content %}
    <p>{{ 'Dear'|trans({}, 'Modules.Pskyc.Shop', language.locale) }} {{ customer_name }},</p>
    
    <p>{{ 'We have successfully received your KYC verification documents and they are now under review.'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}</p>
    
    <div class="info-box">
        <p><strong>{{ 'Verification ID'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}:</strong> #{{ verification_id }}</p>
        <p><strong>{{ 'Status'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}:</strong> {{ 'Under Review'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}</p>
        <p><strong>{{ 'Documents Submitted'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}:</strong> {{ document_count }}</p>
        <p><strong>{{ 'Date Submitted'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}:</strong> {{ date_submitted|date('Y-m-d H:i:s') }}</p>
    </div>
    
    <p>{{ 'Our team will review your documents within 24-48 hours. You will receive an email notification once the review is complete.'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}</p>
    
    <p>{{ 'Thank you for your patience.'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}</p>
    
    <div style="text-align: center;">
        <a href="{{ shop_url }}" class="button">{{ 'Visit'|trans({}, 'Modules.Pskyc.Shop', language.locale) }} {{ shop_name }}</a>
    </div>
{% endblock %}