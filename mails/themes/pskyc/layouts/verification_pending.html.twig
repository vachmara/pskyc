{% extends '@Modules/pskyc/mails/themes/pskyc/layouts/kyc_base.html.twig' %}

{% block title %}{{ 'KYC Verification Pending'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}{% endblock %}

{% block header_color %}#6c757d{% endblock %}
{% block accent_color %}#6c757d{% endblock %}
{% block button_color %}#007cba{% endblock %}

{% block header_subtitle %}{{ 'Verification Pending'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}{% endblock %}

{% block content %}
    <p>{{ 'Dear'|trans({}, 'Modules.Pskyc.Shop', language.locale) }} {{ customer_name }},</p>
    
    <p>{{ 'We have received your KYC verification request and it is currently pending processing.'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}</p>
    
    <div class="info-box">
        <p><strong>{{ 'Verification ID'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}:</strong> #{{ verification_id }}</p>
        <p><strong>{{ 'Status'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}:</strong> {{ 'Pending'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}</p>
        <p><strong>{{ 'Date Submitted'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}:</strong> {{ date_submitted|date('Y-m-d H:i:s') }}</p>
    </div>
    
    <p>{{ 'Your verification request has been added to our processing queue. Our team will begin reviewing your documents shortly.'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}</p>
    
    <p>{{ 'You will receive email updates as your verification progresses through our review process.'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}</p>
    
    <div style="text-align: center;">
        <a href="{{ shop_url }}" class="button">{{ 'Visit'|trans({}, 'Modules.Pskyc.Shop', language.locale) }} {{ shop_name }}</a>
    </div>
{% endblock %}