{% extends '@Modules/pskyc/mails/themes/pskyc/layouts/kyc_base.html.twig' %}

{% block title %}{{ 'KYC Verification Under Review'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}{% endblock %}

{% block header_color %}#ffc107{% endblock %}
{% block accent_color %}#ffc107{% endblock %}
{% block button_color %}#007cba{% endblock %}

{% block header_subtitle %}{{ 'Under Review'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}{% endblock %}

{% block content %}
    <p>{{ 'Dear'|trans({}, 'Modules.Pskyc.Shop', language.locale) }} {{ customer_name }},</p>
    
    <p>{{ 'Your KYC verification documents are currently under review by our team.'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}</p>
    
    <div class="info-box">
        <p><strong>{{ 'Verification ID'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}:</strong> #{{ verification_id }}</p>
        <p><strong>{{ 'Status'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}:</strong> {{ 'Under Review'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}</p>
        <p><strong>{{ 'Date Submitted'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}:</strong> {{ date_submitted|date('Y-m-d H:i:s') }}</p>
    </div>
    
    <p>{{ 'Our verification team is carefully reviewing your submitted documents. This process typically takes 24-48 hours.'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}</p>
    
    <p>{{ 'You will receive an email notification as soon as the review is complete.'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}</p>
    
    <p>{{ 'Thank you for your patience.'|trans({}, 'Modules.Pskyc.Shop', language.locale) }}</p>
    
    <div style="text-align: center;">
        <a href="{{ shop_url }}" class="button">{{ 'Visit'|trans({}, 'Modules.Pskyc.Shop', language.locale) }} {{ shop_name }}</a>
    </div>
{% endblock %}