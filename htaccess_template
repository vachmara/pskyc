# KYC Secure Upload - Block direct access to uploaded documents
# All document access must go through the module's secure download system

# Deny all direct access
<Files "*">
    Order Deny,Allow
    Deny from all
</Files>

# Alternative modern Apache 2.4+ syntax (uncomment if your server supports it)
# <Files "*">
#     Require all denied
# </Files>

# Prevent directory browsing
Options -Indexes

# Disable script execution
