{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block content %}

	{# Header with title and actions #}
	<div class="card">
		<div class="card-header">
			<h3 class="card-header-title">
				<i class="material-icons">verified_user</i>
				{{ 'KYC Verifications'|trans({}, 'Modules.Pskyc.Admin') }}
				<span class="badge badge-primary">{{ pagination.total_count|default(0) }}</span>
			</h3>
			<div class="card-header-toolbar">
				<button type="button" class="btn btn-outline-secondary" onclick="window.location.reload()">
					<i class="material-icons">refresh</i>
					{{ 'Refresh'|trans({}, 'Admin.Actions') }}
				</button>
			</div>
		</div>
		<div class="card-body">
			<form method="get" class="form-inline mb-3">
				<div class="form-group mr-3">
					<label class="form-label mr-2">{{ 'Status'|trans({}, 'Admin.Global') }}:</label>
					<select name="status" class="form-control">
						<option value="">{{ 'All Statuses'|trans({}, 'Modules.Pskyc.Admin') }}</option>
						{% if status_counts is defined and status_counts is not empty %}
							{% for status, count in status_counts %}
								<option value="{{ status }}" {% if filters.status|default('')==status %} selected {% endif %}>
									{{ ('status.' ~ status)|trans({}, 'Modules.Pskyc.Admin') }}
									({{ count }})
								</option>
							{% endfor %}
						{% endif %}
					</select>
				</div>

				<div class="form-group mr-3">
					<label class="form-label mr-2">{{ 'Customer ID'|trans({}, 'Modules.Pskyc.Admin') }}:</label>
					<input type="number" name="customer_id" class="form-control" value="{{ filters.customer_id|default('') }}" placeholder="{{ 'Enter customer ID'|trans({}, 'Modules.Pskyc.Admin') }}">
				</div>

				<div class="form-group mr-3">
					<label class="form-label mr-2">{{ 'Date From'|trans({}, 'Admin.Global') }}:</label>
					<input type="date" name="date_from" class="form-control" value="{{ filters.date_from|default('') }}">
				</div>

				<div class="form-group mr-3">
					<label class="form-label mr-2">{{ 'Date To'|trans({}, 'Admin.Global') }}:</label>
					<input type="date" name="date_to" class="form-control" value="{{ filters.date_to|default('') }}">
				</div>

				<button type="submit" class="btn btn-primary mr-2">
					<i class="material-icons">search</i>
					{{ 'Filter'|trans({}, 'Admin.Actions') }}
				</button>

				<a href="{{ path('admin_pskyc_verification_list') }}" class="btn btn-outline-secondary">
					<i class="material-icons">clear</i>
					{{ 'Reset'|trans({}, 'Admin.Actions') }}
				</a>
			</form>

			{# Status Quick Filters #}
			{% if status_counts is defined and status_counts is not empty %}
				<div class="mb-3">
					<span class="mr-2">{{ 'Quick Filters'|trans({}, 'Modules.Pskyc.Admin') }}:</span>
					<a href="{{ path('admin_pskyc_verification_list') }}" class="btn btn-sm {% if not (filters.status|default('')) %}btn-primary{% else %}btn-outline-primary{% endif %} mr-1">
						{{ 'All'|trans({}, 'Admin.Global') }}
						({{ pagination.total_count|default(0) }})
					</a>
					{% for status, count in status_counts %}
						{% if count > 0 %}
							<a href="{{ path('admin_pskyc_verification_list', {'status': status}) }}" class="btn btn-sm {% if (filters.status|default('')) == status %}btn-primary{% else %}btn-outline-primary{% endif %} mr-1">
								{{ ('status.' ~ status)|trans({}, 'Modules.Pskyc.Admin') }}
								({{ count }})
							</a>
						{% endif %}
					{% endfor %}
				</div>
			{% endif %}
		</div>
	</div>

	{# Main Data Table #}
	<div class="card">
		<div class="card-body">
			{% if verifications is defined and verifications|length > 0 %}
				{# Bulk Actions #}
				<div class="bulk-actions mb-3" style="display: none;">
					<div class="form-inline">
						<select id="bulk-action-select" class="form-control mr-2">
							<option value="">{{ 'Bulk Actions'|trans({}, 'Admin.Actions') }}</option>
							<option value="mark_reviewed">{{ 'Mark as Under Review'|trans({}, 'Modules.Pskyc.Admin') }}</option>
							<option value="delete">{{ 'Delete'|trans({}, 'Admin.Actions') }}</option>
						</select>
						<button type="button" id="apply-bulk-action" class="btn btn-secondary">
							{{ 'Apply'|trans({}, 'Admin.Actions') }}
						</button>
					</div>
				</div>

				<div class="table-responsive">
					<table class="table table-striped table-hover">
						<thead class="thead-light">
							<tr>
								<th width="50">
									<input type="checkbox" id="select-all" class="form-check-input">
								</th>
								<th>{{ 'ID'|trans({}, 'Admin.Global') }}</th>
								<th>{{ 'Customer'|trans({}, 'Admin.Global') }}</th>
								<th>{{ 'Status'|trans({}, 'Admin.Global') }}</th>
								<th>{{ 'Documents'|trans({}, 'Modules.Pskyc.Admin') }}</th>
								<th>{{ 'Submitted'|trans({}, 'Modules.Pskyc.Admin') }}</th>
								<th>{{ 'Last Updated'|trans({}, 'Admin.Global') }}</th>
								<th class="text-center">{{ 'Actions'|trans({}, 'Admin.Actions') }}</th>
							</tr>
						</thead>
						<tbody>
							{% for verification in verifications %}
								<tr>
									<td>
										<input type="checkbox" class="verification-checkbox form-check-input" value="{{ verification.id_kyc_verification }}">
									</td>
									<td>
										<strong>#{{ verification.id_kyc_verification }}</strong>
									</td>
									<td>
										<div>
											<strong>{{ verification.customer_firstname }}
												{{ verification.customer_lastname }}</strong>
											<br>
											<small class="text-muted">{{ verification.customer_email }}</small>
											<br>
											<small class="text-muted">ID:
												{{ verification.id_customer }}</small>
										</div>
									</td>
									<td>
										{% set status_class = {
              'pending': 'warning',
              'under_review': 'info',
              'approved': 'success',
              'rejected': 'danger',
              'expired': 'secondary',
              'requested_more_info': 'warning'
              } %}
										<span class="badge badge-{{ status_class[verification.status]|default('secondary') }}">
											<i class="material-icons" style="font-size: 14px;">
												{% if verification.status == 'approved' %}
													check_circle
												{% elseif verification.status == 'rejected' %}
													cancel
												{% elseif verification.status == 'under_review' %}
													rate_review
												{% elseif verification.status == 'expired' %}
													schedule
												{% else %}
													help
												{% endif %}
											</i>
											{{ ('status.' ~ verification.status)|trans({}, 'Modules.Pskyc.Admin') }}
										</span>
									</td>
									<td>
										<span class="badge badge-light">
											{{ verification.document_count|default(0) }}
											{{ 'documents'|trans({}, 'Modules.Pskyc.Admin') }}
										</span>
									</td>
									<td>
										<small>{{ verification.date_submitted|date('Y-m-d H:i') }}</small>
									</td>
									<td>
										<small>{{ verification.date_updated|date('Y-m-d H:i') }}</small>
									</td>
									<td class="text-center">
										<div class="btn-group" role="group">
											<a href="{{ path('admin_pskyc_verification_view', {'id': verification.id_kyc_verification}) }}" class="btn btn-sm btn-outline-primary" title="{{ 'View Details'|trans({}, 'Admin.Actions') }}">
												<i class="material-icons">visibility</i>
											</a>

											{% if verification.status == 'pending' %}
												<button type="button" class="btn btn-sm btn-outline-success quick-approve" data-verification-id="{{ verification.id_kyc_verification }}" title="{{ 'Quick Approve'|trans({}, 'Modules.Pskyc.Admin') }}">
													<i class="material-icons">check</i>
												</button>
												<button type="button" class="btn btn-sm btn-outline-danger quick-reject" data-verification-id="{{ verification.id_kyc_verification }}" title="{{ 'Quick Reject'|trans({}, 'Modules.Pskyc.Admin') }}">
													<i class="material-icons">close</i>
												</button>
											{% endif %}
										</div>
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>

				{# Pagination #}
				{% if pagination.total_pages > 1 %}
					<nav aria-label="Verification pagination">
						<ul class="pagination justify-content-center">
							{% if pagination.current_page > 1 %}
								<li class="page-item">
									<a class="page-link" href="{{ path('admin_pskyc_verification_list', filters|merge({'page': pagination.current_page - 1})) }}">
										{{ 'Previous'|trans({}, 'Admin.Global') }}
									</a>
								</li>
							{% endif %}

							{% for page in range(max(1, pagination.current_page - 2), min(pagination.total_pages, pagination.current_page +
        2)) %}
								<li class="page-item {% if page == pagination.current_page %}active{% endif %}">
									<a class="page-link" href="{{ path('admin_pskyc_verification_list', filters|merge({'page': page})) }}">
										{{ page }}
									</a>
								</li>
							{% endfor %}

							{% if pagination.current_page < pagination.total_pages %}
								<li class="page-item">
									<a class="page-link" href="{{ path('admin_pskyc_verification_list', filters|merge({'page': pagination.current_page + 1})) }}">
										{{ 'Next'|trans({}, 'Admin.Global') }}
									</a>
								</li>
							{% endif %}
						</ul>
					</nav>
				{% endif %}

			{% else %}
				{# Empty State #}
				<div class="alert alert-info text-center">
					<i class="material-icons" style="font-size: 48px; opacity: 0.5;">verified_user</i>
					<h4>{{ 'No KYC verifications found'|trans({}, 'Modules.Pskyc.Admin') }}</h4>
					<p>{{ 'No verifications have been submitted yet.'|trans({}, 'Modules.Pskyc.Admin') }}</p>
					{% if filters is defined and filters|length > 0 %}
						<a href="{{ path('admin_pskyc_verification_list') }}" class="btn btn-primary">
							{{ 'Clear Filters'|trans({}, 'Modules.Pskyc.Admin') }}
						</a>
					{% endif %}
				</div>
			{% endif %}
		</div>
	</div>


	{# JavaScript for interactions #}
	<script>
		document.addEventListener('DOMContentLoaded', function () { // Select All functionality
const selectAll = document.getElementById('select-all');
const checkboxes = document.querySelectorAll('.verification-checkbox');
const bulkActions = document.querySelector('.bulk-actions');

selectAll.addEventListener('change', function () {
checkboxes.forEach(cb => cb.checked = this.checked);
toggleBulkActions();
});

checkboxes.forEach(cb => {
cb.addEventListener('change', toggleBulkActions);
});

function toggleBulkActions() {
const checkedCount = document.querySelectorAll('.verification-checkbox:checked').length;
bulkActions.style.display = checkedCount > 0 ? 'block' : 'none';
selectAll.checked = checkedCount === checkboxes.length;
}

// Bulk action application
document.getElementById('apply-bulk-action').addEventListener('click', function () {
const action = document.getElementById('bulk-action-select').value;
const selectedIds = Array.from(document.querySelectorAll('.verification-checkbox:checked')).map(cb => cb.value);

if (! action || selectedIds.length === 0) {
alert('{{ 'Please select an action and at least one verification.'|trans({}, 'Modules.Pskyc.Admin') }}');
return;
}

if (action === 'delete' && !confirm('{{ 'Are you sure you want to delete the selected verifications ? '|trans({}, 'Modules.Pskyc.Admin') }}')) {
return;
}

// Send AJAX request
fetch('{{ path('admin_pskyc_verification_bulk_action') }}', {
method: 'POST',
headers: {
'Content-Type': 'application/json',
'X-Requested-With': 'XMLHttpRequest'
},
body: JSON.stringify(
{action: action, verification_ids: selectedIds}
)
}).then(response => response.json()).then(data => {
if (data.success) {
location.reload();
} else {
alert(data.message);
}
}).catch(error => {
console.error('Error:', error);
alert('{{ 'An error occurred while processing the bulk action.'|trans({}, 'Modules.Pskyc.Admin') }}');
});
});

// Quick approve/reject
document.querySelectorAll('.quick-approve, .quick-reject').forEach(btn => {
btn.addEventListener('click', function () {
const verificationId = this.dataset.verificationId;
const isApprove = this.classList.contains('quick-approve');
const status = isApprove ? 'approved' : 'rejected';

if (confirm(`{{ 'Are you sure you want to %action% this verification?'|trans({'%action%': ''}, 'Modules.Pskyc.Admin') }}`.replace('%action%', isApprove ? 'approve' : 'reject'))) {
quickStatusUpdate(verificationId, status);
}
});
});

function quickStatusUpdate(verificationId, status) { // Build the URL properly using the base path
const updateUrl = '{{ path('admin_pskyc_verification_list') }}'.replace('/list', '/' + verificationId + '/status');

fetch(updateUrl, {
method: 'POST',
headers: {
'Content-Type': 'application/x-www-form-urlencoded',
'X-Requested-With': 'XMLHttpRequest'
},
body: new URLSearchParams(
{
status: status,
admin_note: 'Quick ' + status + ' from list view'
}
).toString()
}).then(response => {
if (response.ok) {
location.reload();
} else {
throw new Error('HTTP ' + response.status);
}
}).catch(error => {
console.error('Error:', error);
alert('{{ 'An error occurred while updating the verification.'|trans({}, 'Modules.Pskyc.Admin') }}');
});
}
});
	</script>
{% endblock %}
