{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block content %}
	<div class="card">
		<div class="card-header d-flex justify-content-between align-items-center">
			<h3 class="card-header-title mb-0">
				<i class="material-icons">visibility</i>
				{{ 'Details'|trans({}, 'Modules.Pskyc.Admin') }}
				<span class="badge badge-secondary ml-2">#{{ verification.id_kyc_verification }}</span>
			</h3>
			<a href="{{ path('ps_pskyc_verification_index') }}" class="btn btn-outline-secondary">
				<i class="material-icons">arrow_back</i>
				{{ 'Back to list'|trans({}, 'Admin.Actions') }}
			</a>
		</div>

		<div class="card-body">
			<div
				class="row">
				{# Customer Information #}
				<div class="col-md-6">
					<div class="card">
						<div class="card-header">
							<h4 class="card-header-title">
								<i class="material-icons">person</i>
								{{ 'Customer Information'|trans({}, 'Modules.Pskyc.Admin') }}
							</h4>
						</div>
						<div class="card-body">
							<table class="table table-striped">
								<tr>
									<td>
										<strong>{{ 'Customer ID'|trans({}, 'Modules.Pskyc.Admin') }}:</strong>
									</td>
									<td>{{ verification.id_customer }}</td>
								</tr>
								<tr>
									<td>
										<strong>{{ 'Email'|trans({}, 'Admin.Global') }}:</strong>
									</td>
									<td>{{ verification.customer.email|default('-') }}</td>
								</tr>
								<tr>
									<td>
										<strong>{{ 'Name'|trans({}, 'Admin.Global') }}:</strong>
									</td>
									<td>{{ verification.customer.firstname|default('-') }}
										{{ verification.customer.lastname|default('-') }}</td>
								</tr>
							</table>
						</div>
					</div>
				</div>

				{# Verification Status #}
				<div class="col-md-6">
					<div class="card">
						<div class="card-header">
							<h4 class="card-header-title">
								<i class="material-icons">assignment</i>
								{{ 'Verification Status'|trans({}, 'Modules.Pskyc.Admin') }}
							</h4>
						</div>
						<div class="card-body">
							<table class="table table-striped">
								<tr>
									<td>
										<strong>{{ 'Status'|trans({}, 'Admin.Global') }}:</strong>
									</td>
									<td>
										{% set status_class = '' %}
										{% if verification.status == 'pending' %}
											{% set status_class = 'badge-warning' %}
										{% elseif verification.status == 'approved' %}
											{% set status_class = 'badge-success' %}
										{% elseif verification.status == 'rejected' %}
											{% set status_class = 'badge-danger' %}
										{% elseif verification.status == 'under_review' %}
											{% set status_class = 'badge-info' %}
										{% else %}
											{% set status_class = 'badge-secondary' %}
										{% endif %}
										<span class="badge {{ status_class }}">
											{{ verification.status|trans({}, 'Modules.Pskyc.Admin') }}
										</span>
									</td>
								</tr>
								<tr>
									<td>
										<strong>{{ 'Submitted'|trans({}, 'Modules.Pskyc.Admin') }}:</strong>
									</td>
									<td>{{ verification.date_submitted|date('Y-m-d H:i:s') }}</td>
								</tr>
								<tr>
									<td>
										<strong>{{ 'Last Updated'|trans({}, 'Modules.Pskyc.Admin') }}:</strong>
									</td>
									<td>{{ verification.date_validated|date('Y-m-d H:i:s')|default('-') }}</td>
								</tr>
							</table>
						</div>
					</div>
				</div>
			</div>

			{# Documents Section #}
			{% if verification.documents is defined and verification.documents %}
				<div class="card mt-3">
					<div class="card-header">
						<h4 class="card-header-title">
							<i class="material-icons">attachment</i>
							{{ 'Submitted Documents'|trans({}, 'Modules.Pskyc.Admin') }}
						</h4>
					</div>
					<div class="card-body">
						<div class="table-responsive">
							<table class="table table-striped">
								<thead>
									<tr>
										<th>{{ 'Document Type'|trans({}, 'Modules.Pskyc.Admin') }}</th>
										<th>{{ 'Preview'|trans({}, 'Modules.Pskyc.Admin') }}</th>
										<th>{{ 'Side'|trans({}, 'Modules.Pskyc.Admin') }}</th>
										<th>{{ 'Upload Date'|trans({}, 'Modules.Pskyc.Admin') }}</th>
										<th>{{ 'Actions'|trans({}, 'Admin.Actions') }}</th>
									</tr>
								</thead>
								<tbody>
									{% for document in verification.documents %}
										<tr>
											<td>
												<i class="material-icons">
													{% if document.type == 'identity' %}
														credit_card
													{% elseif document.type == 'address_proof' %}
														home
													{% else %}
														description
													{% endif %}
												</i>
												{{ document.type|trans({}, 'Modules.Pskyc.Admin') }}
											</td>
											<td>
												{% if document.mime is defined and document.mime starts with 'image/' %}
													<a href="{{ path('ps_pskyc_document_download', {documentId: document.id_kyc_document, preview: 1}) }}" target="_blank" rel="noopener">
														<img src="{{ path('ps_pskyc_document_download', {documentId: document.id_kyc_document, preview: 1}) }}" alt="Preview" style="max-width:250px;max-height:250px;">
													</a>
												{% else %}
													<span class="text-muted">{{ 'No preview'|trans({}, 'Modules.Pskyc.Admin') }}</span>
												{% endif %}
											</td>
											<td>
												{% if document.side == 'front' %}
													<span class="badge badge-primary">{{ 'Front'|trans({}, 'Modules.Pskyc.Admin') }}</span>
												{% elseif document.side == 'back' %}
													<span class="badge badge-secondary">{{ 'Back'|trans({}, 'Modules.Pskyc.Admin') }}</span>
												{% else %}
												-
												{% endif %}
											</td>
											<td>{{ document.date_uploaded|date('Y-m-d H:i:s') }}</td>
											<td>
												<a href="{{ path('ps_pskyc_document_download', {documentId: document.id_kyc_document}) }}" class="btn btn-sm btn-outline-primary" title="{{ 'Download'|trans({}, 'Admin.Actions') }}">
													<i class="material-icons">download</i>
												</a>
											</td>
										</tr>
									{% endfor %}
								</tbody>
							</table>
						</div>
					</div>
				</div>
			{% endif %}

			{# Admin Notes Section #}
			<div class="card mt-3">
				<div class="card-header">
					<h4 class="card-header-title">
						<i class="material-icons">note</i>
						{{ 'Admin Notes'|trans({}, 'Modules.Pskyc.Admin') }}
					</h4>
				</div>
				<div class="card-body">
					<form method="post" action="{{ path('ps_pskyc_verification_update_note', {verificationId: verification.id_kyc_verification}) }}">
						<div class="form-group">
							<label for="admin_note">{{ 'Add/Update Note'|trans({}, 'Modules.Pskyc.Admin') }}:</label>
							<textarea name="admin_note" id="admin_note" class="form-control" rows="3" placeholder="{{ 'Add your notes here...'|trans({}, 'Modules.Pskyc.Admin') }}">{{ verification.admin_note }}</textarea>
						</div>

						<div class="form-group">
							<div class="btn-group">
								<button type="submit" class="btn btn-secondary" name="action" value="update_note">
									<i class="material-icons">save</i>
									{{ 'Update Note Only'|trans({}, 'Modules.Pskyc.Admin') }}
								</button>
							</div>
						</div>
					</form>

					<div class="mt-3">
						<form method="post" action="{{ path('ps_pskyc_verification_approve', {verificationId: verification.id_kyc_verification}) }}">
							<button type="submit" class="btn btn-success" name="action" value="approve">
								<i class="material-icons">check</i>
								{{ 'Approve'|trans({}, 'Modules.Pskyc.Admin') }}
							</button>
						</form>

						<form method="post" action="{{ path('ps_pskyc_verification_reject', {verificationId: verification.id_kyc_verification}) }}">
							<button type="submit" class="btn btn-danger" name="action" value="reject">
								<i class="material-icons">close</i>
								{{ 'Reject'|trans({}, 'Modules.Pskyc.Admin') }}
							</button>
						</form>

						<form method="post" action="{{ path('ps_pskyc_verification_request_info', {verificationId: verification.id_kyc_verification}) }}">
							<button type="submit" class="btn btn-warning" name="action" value="request_info">
								<i class="material-icons">help</i>
								{{ 'Request More Info'|trans({}, 'Modules.Pskyc.Admin') }}
							</button>
						</form>
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
